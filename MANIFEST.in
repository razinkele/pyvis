# Include package data
recursive-include pyvis/templates *
recursive-include pyvis/lib *
recursive-include pyvis/shiny *.js

# Include documentation
include README.md
include LICENSE
include CHANGELOG.md
include pyvis/_version.py

# Include improvement documentation
include OPTIMIZATION_REPORT.md
include IMPROVEMENTS_ROUND_2.md
include COMPLETE_IMPROVEMENTS_SUMMARY.md
include FINAL_IMPLEMENTATION_SUMMARY.md
include SHINY_INTEGRATION_IMPROVEMENTS.md
include SHINY_QUICKSTART.md

# Include examples
include benchmark_improvements.py
include test_new_features.py
include shiny_modern_example.py
include shiny_example.py

# Exclude development files
exclude .gitignore
exclude .coveragerc
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude * .pytest_cache
recursive-exclude .github *
recursive-exclude docs *
recursive-exclude notebooks *
recursive-exclude examples *.html
